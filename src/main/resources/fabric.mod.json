{
	"schemaVersion": 1,
	"id": "alternatemc",
	"version": "${version}",
	"name": "AlternateMC",
	"description": "This is an example description! Tell everyone what your mod is about!",
	"authors": [
		"Me!"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "CC0-1.0",
	"icon": "assets/alternatemc/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"net.kidsplash.alternatemc.AlternateMC"
		],
		"client": [
			"net.kidsplash.alternatemc.client.AlternateMCClient"
		],
		"fabric-datagen": [
			"net.kidsplash.alternatemc.client.AlternateMCDataGenerator"
		]
	},
	"mixins": [
		"alternatemc.mixins.json",
		{
			"config": "alternatemc.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.3",
		"minecraft": "~26.2",
		"java": ">=25",
		"fabric-api": "*"
	}
}